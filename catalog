<script>

function getCart(){
    return JSON.parse(localStorage.getItem("cart")) || [];
}

function saveCart(cart){
    localStorage.setItem("cart", JSON.stringify(cart));
}

function updateCartCount(){
    document.getElementById("cartCount").innerText = getCart().length;
}

function cartCenter(){
    const el = document.getElementById("cartCount");
    const r = el.getBoundingClientRect();

    return {
        x:r.left + r.width/2,
        y:r.top + r.height/2
    };
}

function addToCart(name,price,btn,img){

    let cart = getCart();

    cart.push({
        name,
        price: Number(price),
        img
    });

    saveCart(cart);
    updateCartCount();

    const start = btn.getBoundingClientRect();
    const end = cartCenter();

    const fly = document.createElement("img");
    fly.src = img;
    fly.className = "fly";
    document.body.appendChild(fly);

    fly.style.left = start.left + "px";
    fly.style.top = start.top + "px";

    requestAnimationFrame(()=>{

        fly.style.transform =
        `translate(${end.x - start.left}px, ${end.y - start.top}px) scale(0.2)`;

        fly.style.opacity = "0";

    });

    setTimeout(()=>fly.remove(),800);

    const badge = document.getElementById("cartCount");
    badge.classList.add("cart-bounce");

    setTimeout(()=>badge.classList.remove("cart-bounce"),400);
}

function setFilter(type,btn){

    document.querySelectorAll(".filter-btn")
    .forEach(b=>b.classList.remove("active"));

    btn.classList.add("active");

    document.querySelectorAll(".product")
    .forEach(p=>{
        p.style.display =
        (type==="all" || p.classList.contains(type))
        ? "block"
        : "none";
    });
}

updateCartCount();

</script>

