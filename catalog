<style>
body {
    background:#f4f6f8;
    font-family:Arial;
}

.container {
    max-width:1100px;
}

/* NAV */
.navbar .container{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

/* карточки */
.card {
    border:none;
    border-radius:16px;
    overflow:hidden;
    box-shadow:0 6px 18px rgba(0,0,0,0.1);
    transition:0.3s;
}

.card:hover {
    transform:translateY(-6px);
}

.card img {
    height:280px;
    width:100%;
    object-fit:cover;
}

/* фильтр */
.filter-btn.active {
    background:black;
    color:white;
}

/* бейдж */
.cart-bounce {
    animation: bounce 0.4s;
}

@keyframes bounce {
    0% {transform:scale(1);}
    50% {transform:scale(1.4);}
    100% {transform:scale(1);}
}

/* летящий товар */
.fly {
    position:fixed;
    width:50px;
    height:50px;
    border-radius:10px;
    object-fit:cover;
    z-index:9999;
    pointer-events:none;
    transition: all 0.8s cubic-bezier(.2,.8,.2,1);
}

/* SALE */
.sale-badge{
    position:absolute;
    top:10px;
    left:10px;
    background:red;
    color:white;
    padding:5px 10px;
    border-radius:10px;
    font-size:12px;
    font-weight:bold;
}

.card-wrapper{
    position:relative;
}

/* цены */
.sale-price{
    color:red;
    font-weight:bold;
    font-size:18px;
}

.old-price{
    color:gray;
    text-decoration:line-through;
    margin-left:8px;
    font-size:14px;
}
</style>
</head>

