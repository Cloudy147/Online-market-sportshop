<!DOCTYPE html>
<html lang="ru">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SportShop</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    font-family: Arial;
    background: #f4f6f8;
}

/* HERO */
.hero{
    background: linear-gradient(135deg, #111, #333);
    color:white;
    padding: 100px 20px;
    text-align:center;
    border-radius: 0 0 30px 30px;
}

.hero h1{
    font-size: 48px;
    font-weight: bold;
}

.hero p{
    font-size: 18px;
    opacity: 0.8;
}

/* КНОПКИ */
.btn-main{
    padding: 12px 25px;
    border-radius: 12px;
    font-weight: bold;
}

/* БЛОКИ */
.feature{
    background:white;
    padding:20px;
    border-radius:16px;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
    text-align:center;
    transition:0.3s;
}

.feature:hover{
    transform: translateY(-5px);
}

/* ТОВАРЫ */
.product-card{
    background:white;
    border-radius:16px;
    overflow:hidden;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
    transition:0.3s;
}

.product-card:hover{
    transform: translateY(-6px);
}

.product-card img{
    height:220px;
    width:100%;
    object-fit:cover;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-dark bg-dark">
<div class="container">
    <a class="navbar-brand" href="index.html">SportShop</a>

    <div>
        <a class="btn btn-outline-light" href="index.html">Главная</a>
        <a class="btn btn-outline-light" href="catalog.html">Каталог</a>
    </div>
</div>
</nav>

<!-- HERO -->
<div class="hero">
    <h1>SportShop</h1>
    <p>Лучшие кроссовки и спортивная одежда</p>

    <a href="catalog.html" class="btn btn-light btn-main mt-3">
        Перейти в каталог
    </a>
</div>

<!-- ПРЕИМУЩЕСТВА -->
<div class="container mt-5">
<div class="row g-3">

    <div class="col-md-4">
        <div class="feature">
            <h5>🔥 Новые коллекции</h5>
            <p>Каждую неделю обновление товаров</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="feature">
            <h5>🚚 Быстрая доставка</h5>
            <p>Доставка по городу за 24 часа</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="feature">
            <h5>💳 Удобная оплата</h5>
            <p>Наличные или карта</p>
        </div>
    </div>

</div>
</div>

<!-- ПРЕВЬЮ ТОВАРОВ -->
<div class="container mt-5">
<h3 class="mb-3">Популярные товары</h3>

<div class="row g-4">

    <div class="col-md-4">
        <div class="product-card">
            <img src="Images/nike.jpg">
            <div class="p-3 text-center">
                <h5>Nike Air Max</h5>
                <p>120 AZN</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="product-card">
            <img src="Images/adidas.jpg">
            <div class="p-3 text-center">
                <h5>Adidas Ultraboost</h5>
                <p>150 AZN</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="product-card">
            <img src="Images/puma.jpg">
            <div class="p-3 text-center">
                <h5>Puma RS-X</h5>
                <p>130 AZN</p>
            </div>
        </div>
    </div>

</div>
</div>

<!-- FOOTER -->
<div class="text-center mt-5 p-4" style="background:#111; color:white;">
    © 2026 SportShop
</div>

</body>
</html>
