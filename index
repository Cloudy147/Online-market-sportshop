<!DOCTYPE html>
<html lang="ru">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SportShop</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    font-family: Arial;
    background: #f4f6f8;
}

/* HERO */
.hero{
    background: linear-gradient(135deg, #111, #333);
    color:white;
    padding: 90px 20px;
    text-align:center;
    border-radius: 0 0 30px 30px;
}

.hero h1{
    font-size: 48px;
    font-weight: bold;
}

.hero p{
    font-size: 18px;
    opacity: 0.8;
}

/* кнопка */
.btn-main{
    padding: 12px 25px;
    border-radius: 12px;
    font-weight: bold;
}

/* карточки */
.product-card{
    background:white;
    border-radius:16px;
    overflow:hidden;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
    transition:0.3s;
}

.product-card:hover{
    transform: translateY(-6px);
}

.product-card img{
    height:220px;
    width:100%;
    object-fit:cover;
}

/* скидка */
.sale-price{
    color:red;
    font-weight:bold;
    font-size:20px;
}

.old-price{
    color:gray;
    text-decoration:line-through;
    margin-left:8px;
    font-size:14px;
}

/* feature */
.feature{
    background:white;
    padding:20px;
    border-radius:16px;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
    text-align:center;
    transition:0.3s;
}

.feature:hover{
    transform: translateY(-5px);
}

/* FOOTER */
footer{
    background:#111;
    color:white;
}

footer a{
    color:white;
    text-decoration:none;
}

footer a:hover{
    color:#ffc107;
}

</style>
</head>

